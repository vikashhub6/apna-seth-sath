        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Mujhe sir dard ho raha hai ghantey se, aur main thak gaya hun. Kya khoob isse bachne ka tareeka?\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:5001/api/aibot/chat",
